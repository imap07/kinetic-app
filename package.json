{
  "name": "kinetic-app",
  "version": "1.0.0",
  "main": "index.ts",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "node scripts/bump-build.js",
    "build:ios": "node scripts/bump-build.js",
    "build:android": "bash scripts/build-android.sh",
    "build:android:production": "bash scripts/build-android.sh --production",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^expo/src/winter/runtime\\.native$": "<rootDir>/jest.winter-stub.js",
      "^expo/src/winter/runtime$": "<rootDir>/jest.winter-stub.js",
      "^expo/src/winter/installGlobal$": "<rootDir>/jest.winter-stub.js",
      "^expo/src/winter/ImportMetaRegistry$": "<rootDir>/jest.winter-stub.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@sentry/.*|sentry-expo|native-base|react-native-svg|@react-native-async-storage/.*))"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/ios/",
      "/android/"
    ],
    "modulePathIgnorePatterns": [
      "<rootDir>/ios/",
      "<rootDir>/android/"
    ],
    "roots": [
      "<rootDir>/src"
    ],
    "rootDir": "."
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/metro-runtime": "~55.0.6",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-firebase/analytics": "^23.8.8",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.15.7",
    "@react-navigation/native": "^7.2.0",
    "@react-navigation/native-stack": "^7.14.7",
    "@sentry/react-native": "~7.11.0",
    "expo": "~55.0.15",
    "expo-apple-authentication": "~55.0.13",
    "expo-blur": "~55.0.14",
    "expo-build-properties": "~55.0.13",
    "expo-camera": "~55.0.15",
    "expo-clipboard": "~55.0.13",
    "expo-constants": "~55.0.9",
    "expo-device": "~55.0.15",
    "expo-font": "~55.0.4",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.8",
    "expo-image-picker": "~55.0.18",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.13",
    "expo-local-authentication": "~55.0.13",
    "expo-localization": "~55.0.13",
    "expo-navigation-bar": "~55.0.12",
    "expo-notifications": "~55.0.19",
    "expo-secure-store": "~55.0.13",
    "expo-sharing": "~55.0.18",
    "expo-status-bar": "~55.0.5",
    "expo-store-review": "~55.0.13",
    "expo-system-ui": "~55.0.15",
    "expo-tracking-transparency": "~55.0.13",
    "i18next": "^26.0.3",
    "lottie-react-native": "~7.3.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-i18next": "^17.0.2",
    "react-native": "0.83.6",
    "react-native-google-mobile-ads": "^16.3.1",
    "react-native-purchases": "^9.14.0",
    "react-native-purchases-ui": "^9.14.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-toast-message": "^2.3.3",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "jest": "^30.3.0",
    "jest-expo": "^55.0.16",
    "react-test-renderer": "19.2.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
