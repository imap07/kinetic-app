{
  "expo": {
    "name": "Kinetic",
    "slug": "kinetic-app",
    "scheme": "kinetic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0E11"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "io.kinetic.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Kinetic uses your camera to update your profile photo.",
        "NSPhotoLibraryUsageDescription": "Kinetic accesses your photo library to update your profile photo."
      },
      "appleTeamId": "QY9J3TC5L3"
    },
    "android": {
      "package": "io.kinetic.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0B0E11",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.942851412014-0v2iuf4dj6ji0sm4hqnblqvme0g2qsle"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C6FF00"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Kinetic uses Face ID to securely log you in."
        }
      ],
      "expo-apple-authentication",
      "expo-image",
      "@react-native-firebase/app",
      "./plugins/withFirebaseModularHeaders"
    ],
    "extra": {
      "eas": {
        "projectId": "fa9ef7e4-a38e-414e-980e-965ddd976b1a"
      }
    },
    "owner": "redakcode"
  }
}
