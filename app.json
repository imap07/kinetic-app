{
  "expo": {
    "name": "Kinetic",
    "slug": "kinetic-app",
    "version": "1.0.0",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/fa9ef7e4-a38e-414e-980e-965ddd976b1a"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B0E11"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "io.kinetic.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Kinetic uses your camera to update your profile photo.",
        "NSPhotoLibraryUsageDescription": "Kinetic accesses your photo library to update your profile photo."
      }
    },
    "android": {
      "package": "io.kinetic.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#0B0E11",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.942851412014-0v2iuf4dj6ji0sm4hqnblqvme0g2qsle"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#C6FF00"
        }
      ],
      "expo-apple-authentication",
      "expo-image"
    ],
    "extra": {
      "eas": {
        "projectId": "fa9ef7e4-a38e-414e-980e-965ddd976b1a"
      }
    },
    "owner": "redakcode"
  }
}
